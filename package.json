{
  "name": "@yy-web/request",
  "type": "module",
  "version": "1.5.9",
  "packageManager": "pnpm@10.19.0",
  "description": "yyweb request",
  "author": "Wangsh <949066041@qq.com>",
  "license": "MIT",
  "funding": "https://github.com/a949066041",
  "homepage": "https://github.com/yydy-web",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yydy-web/request.git"
  },
  "bugs": {
    "url": "https://github.com/yydy-web/request/issues"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "dev": "pnpm run build --watch",
    "build": "tsdown src/index.ts --format cjs,esm --dts --no-splitting --config tsdown.json",
    "release": "bumpp --commit --push --tag",
    "test": "vitest",
    "lint": "eslint .",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@vitest/ui": "^4.0.3",
    "msw": "^2.11.6",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.1.0",
    "@types/node": "^20.19.23",
    "@vitest/browser": "^4.0.3",
    "@vitest/coverage-istanbul": "^4.0.3",
    "axios": "^1.12.2",
    "bumpp": "^10.3.1",
    "eslint": "^9.38.0",
    "jsdom": "^27.0.1",
    "tsdown": "^0.15.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
