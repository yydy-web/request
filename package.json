{
  "name": "@yy-web/request",
  "version": "1.5.9",
  "packageManager": "pnpm@9.5.0",
  "description": "yyweb request",
  "author": "Wangsh <949066041@qq.com>",
  "license": "MIT",
  "funding": "https://github.com/a949066041",
  "type": "module",
  "homepage": "https://github.com/yydy-web",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yydy-web/request.git"
  },
  "bugs": {
    "url": "https://github.com/yydy-web/request/issues"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "dev": "pnpm run build --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --no-splitting --config tsup.json",
    "release": "bumpp --commit --push --tag",
    "test": "vitest",
    "lint": "eslint .",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.22.0",
    "@types/node": "^20.14.10",
    "@vitest/coverage-istanbul": "^2.0.2",
    "axios": "^1.7.2",
    "bumpp": "^9.4.1",
    "eslint": "^9.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  },
  "dependencies": {
    "@vitest/ui": "^2.0.2"
  }
}
