{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["rsbuild.config.*", "mock/**/*", "vitest.config.*", "cypress.config.*", "playwright.config.*"]
}
